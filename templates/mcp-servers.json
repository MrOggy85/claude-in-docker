{
  "mcpServers": {
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${MCP_GH_BEARER}"
      }
    },
    "chrome-devtools": {
      "type": "http",
      "url": "http://host.docker.internal:9333/mcp"
    }
  }
}
